{
  "name": "mei-controle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently -n api,web -c cyan,magenta \"npm run server\" \"wait-on file:.dev-server-port -t 120000 && npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "server": "node --watch server/index.js",
    "start:prod": "node server/index.js",
    "install:production": "node scripts/install-production.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "lucide-react": "^0.323.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "wait-on": "^9.0.10"
  }
}
