# Copie para .env na raiz do projeto (ou defina as mesmas chaves no painel da Hostinger).
# O servidor lê primeiro variáveis já definidas no ambiente; o arquivo .env preenche o que faltar.

NODE_ENV=production
PORT=3001

# Obrigatório em produção: string longa e aleatória (ex.: openssl rand -base64 32)
JWT_SECRET=

# URL pública do site, sem barra no final (links de e-mail, Mercado Pago, etc.)
BASE_URL=https://seu-dominio.com

# Opcional — Mercado Pago (developers.mercadopago.com.br)
MERCADOPAGO_ACCESS_TOKEN=

# Opcional — se o front estiver em outro domínio que o da API
# CORS_ORIGIN=https://outro-dominio.com

# Frontend (Vite): só necessário se API e dev server forem portas diferentes
# VITE_API_URL=http://localhost:3002/api
# VITE_PROXY_TARGET=http://localhost:3002
